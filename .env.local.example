# ─────────────────────────────────────────────────────────────
# OctaUnitech Chatbot — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── Gmail SMTP (default) ──────────────────────────────────────
# Step-by-step: Gmail App Password
#   1. Go to myaccount.google.com → Security
#   2. Enable 2-Step Verification (required)
#   3. Search "App passwords" in the search bar
#   4. Select app: Mail  |  Select device: Other → name it "OctaUnitech"
#   5. Google generates a 16-character password — paste it below
#   6. Use that password as SMTP_PASS (NOT your Gmail login password)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sender@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Email address that receives the chat transcripts
ADMIN_EMAIL=sales@octaunitech.com

# ─────────────────────────────────────────────────────────────
# Alternative: Microsoft Outlook / Office 365
# ─────────────────────────────────────────────────────────────
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=your-account@outlook.com
# SMTP_PASS=your-outlook-password

# ─────────────────────────────────────────────────────────────
# Alternative: Yahoo Mail
# ─────────────────────────────────────────────────────────────
# SMTP_HOST=smtp.mail.yahoo.com
# SMTP_PORT=587
# SMTP_USER=your-account@yahoo.com
# SMTP_PASS=your-yahoo-app-password
# Note: Yahoo also requires an App Password — similar steps to Gmail.

# ─────────────────────────────────────────────────────────────
# Alternative: Custom SMTP / AWS SES / SendGrid
# ─────────────────────────────────────────────────────────────
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com   # AWS SES example
# SMTP_PORT=587
# SMTP_USER=AKIAIOSFODNN7EXAMPLE
# SMTP_PASS=your-ses-smtp-secret
